# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="AIOP - Enterprise AI Platform"
DEBUG=false

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=aiop
POSTGRES_PASSWORD=aiop_secret          # change in production
POSTGRES_DB=aiop_db

# ─── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this   # openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Options: openai | anthropic | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Ollama (local) ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# ─── RAG ─────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# ─── Uploads ─────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ─── MLflow (V3) ─────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=aiop-rag-platform
